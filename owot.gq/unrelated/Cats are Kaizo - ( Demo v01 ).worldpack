{"prophecyStrings":["{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Looks like the rest of the room is unfinished.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"No... This can't end like this.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"This isn't right.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"THIS ISN'T RIGHT!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"I've spent so much time preparing the narration for this pack, just for it to be unfinished?!\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"This is not real.\",\"endWait\":19.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Anyone recording right now?\",\"endWait\":27.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"No?\",\"endWait\":20.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Ugh....\",\"endWait\":19.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"I can't believe i have to say this, but...\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"The cat jumped into the void\",\"endWait\":0.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Hey!\",\"endWait\":20.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"W-Wait, you can TALK?!\",\"endWait\":6.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"No time to discuss. I'm not going to do a suicide mission because you said so.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"But how do you even cross this pit then?\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"I have my own ways. Check this out.\",\"endWait\":30.0,\"playerSkippable\":false,\"runParallel\":false}","{\"connectedButtonGUID\":\"6a00a431-2c96-4d3b-8d73-243c4c7c44de\"}","{\"performers\":[1],\"lumiMoving\":true,\"redMoving\":false,\"greenMoving\":false,\"blueMoving\":false,\"purpleMoving\":false,\"moveType\":20,\"duration\":0.0,\"runParallel\":true}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.ButtonProphecy","ProphecySystem.MoveProphecy"],"removePlayerControlUntilTold":true,"companionActivated":false}

