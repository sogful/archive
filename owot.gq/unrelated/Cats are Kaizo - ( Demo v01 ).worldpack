{"prophecyStrings":["{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Dev note №4:\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"for some reason this place in the room feels so peaceful, like, yeah, there is a giant pool of lava here but the top platform was fully designed by lastquarter despite this part being normally inaccessible, so it feels like it was meant to be explored\",\"endWait\":30.0,\"playerSkippable\":true,\"runParallel\":false}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy"],"removePlayerControlUntilTold":false,"companionActivated":false}

