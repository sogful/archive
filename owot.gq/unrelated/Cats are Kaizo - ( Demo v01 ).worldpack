{"prophecyStrings":["{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"this pack is a full copy of the original game, except the obstacles are hi\",\"endWait\":0.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"NO.\",\"endWait\":18.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"w-what, you can TALK?!\",\"endWait\":4.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Not funny. What did you do.\",\"endWait\":21.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"uuh, nothing??\",\"endWait\":7.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Lies.\",\"endWait\":19.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"well, i didn't finish a little bit of it\",\"endWait\":0.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"A LITTLE BIT?? 9 WORLDS?? THAT'S WHAT YOU CALL A LITTLE BIT??\",\"endWait\":19.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"okay, i'm so\",\"endWait\":0.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"WHEN YOU WERE MAKING THIS PACK, YOU WERE PLANNING TO MAKE AT LEAST HALF OF IT RIGHT? AND YOU FAILED TO DO EVEN THAT.\",\"endWait\":24.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"*sigh*\",\"endWait\":19.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"i guess it was not worth it.\",\"endWait\":19.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"none of this was worth it.\",\"endWait\":18.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[0],\"lumiTalking\":false,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"i'm going to delete this all like it didn't happen.\",\"endWait\":19.0,\"playerSkippable\":true,\"runParallel\":false}","{\"performers\":[1],\"lumiTalking\":true,\"redTalking\":false,\"greenTalking\":false,\"blueTalking\":false,\"purpleTalking\":false,\"dialogue\":\"Wait!\",\"endWait\":17.0,\"playerSkippable\":true,\"runParallel\":false}","{\"effectType\":3,\"duration\":0.0,\"runParallel\":true}","{\"connectedButtonGUID\":\"dc83c1ea-99af-4ba0-b017-b3e4cc55ec73\"}"],"prophecyTypeStrings":["ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","ProphecySystem.TalkProphecy","Pro